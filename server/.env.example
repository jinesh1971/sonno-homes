S3_REGION="eu-south-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# Server
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM="Sonno Homes <onboarding@resend.dev>"
