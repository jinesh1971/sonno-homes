# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/sonno_homes?schema=public"

# Clerk
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
